# Copy to .env and fill in. Never commit a real .env (it is gitignored).

# --- LLM provider ---
# Local development (default): free, private, no key required.
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1
OLLAMA_HOST=http://localhost:11434

# Production / hosted (set LLM_PROVIDER=openai_compatible to use these):
# Groq (free, fast):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.1-8b-instant
# OpenRouter (free models available):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
# LLM_API_KEY=your_key_here

# --- Database ---
# Dev default is local SQLite; deployment sets a Postgres URL (e.g. Neon/Supabase).
# A `postgres://` URL is auto-normalized to `postgresql://`, so paste the
# provider's connection string verbatim. (Vercel's filesystem is ephemeral, so
# SQLite won't persist there — use Postgres in production.)
DATABASE_URL=sqlite:///./triageiq.db

# --- CORS ---
# Comma-separated allowed frontend origins. In production set this to the
# deployed triageiq-web URL, e.g. https://triageiq-web.vercel.app
CORS_ORIGINS=http://localhost:3000
